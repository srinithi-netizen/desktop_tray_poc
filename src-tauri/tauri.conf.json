{
  "productName": "fluxbooks-desktop-tray",
  "version": "0.1.1",
  "identifier": "com.fluxbooks.desktop",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420"
  },
  "app": {
    "withGlobalTauri": false,
    "windows": [
      {
        "label": "main",
        "title": "FluxBooks Desktop Tray",
        "width": 520,
        "height": 680,
        "resizable": true,
        "visible": true
      }
    ],
 
    "security": {
      "csp": "default-src 'self'; connect-src http://localhost:3001; script-src 'self'"
    }
  
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    
    "externalBin": ["binaries/server"],
  
      
"resources": [
  "resources/server",
  "resources/postgres-linux"
]    
  }
  
}