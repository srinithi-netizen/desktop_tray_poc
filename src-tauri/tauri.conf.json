{
  "productName": "fluxbooks-desktop-tray",
  "version": "0.1.1",
  "identifier": "com.fluxbooks.desktop",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420"
  },
  "app": {
    "withGlobalTauri": false,
    "windows": [
      {
        "label": "main",
        "title": "FluxBooks Desktop Tray",
        "width": 520,
        "height": 680,
        "resizable": true,
        "visible": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
   "resources": {
      "resources/server.exe": "server.exe"
    }
  }
  
}